# Inherit the parent embedded/ devenv shell (which provides ravedude,
# avr-gcc, avrdude, etc.), then override the Rust toolchain to upstream
# nightly with AVR LLVM backend (exported as $AVR_RUST by the parent).
#
# This is the only place in the workspace that needs a non-esp Rust toolchain.
source_up
PATH_add "$AVR_RUST/bin"
