# Inherit the parent embedded/ devenv shell (which provides ravedude,
# avr-gcc, avrdude, etc.), then override the Rust toolchain to upstream
# nightly with the AVR LLVM backend (exported as $AVR_RUST by the parent).
#
# This is the only kind of crate in the workspace that needs a non-esp
# Rust toolchain. See ../../TARGETS.md for the full explanation.
source_up
PATH_add "$AVR_RUST/bin"
